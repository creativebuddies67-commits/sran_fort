NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# Server-side Strapi URL for API proxy (booking form) — keep as localhost when Next.js runs on same machine
STRAPI_URL=http://localhost:1337
# Set to true only for offline dev without Strapi — false uses admin-uploaded photos
NEXT_PUBLIC_USE_STATIC_IMAGES=false

# Optional: secret for instant cache refresh when Strapi content changes
# Set up a webhook in Strapi admin → Settings → Webhooks → POST to:
# http://localhost:3000/api/revalidate?secret=your-secret-here
REVALIDATE_SECRET=change-me-in-production

# About Us slider images — upload multiple in Strapi: Site Settings → About Images
# About Us video link (shown below slider). Use a watch/youtu.be link, not the channel URL.
NEXT_PUBLIC_ABOUT_YOUTUBE_URL=https://youtu.be/sesx8Q4Gs6A

# Email notifications when a booking inquiry is submitted
INQUIRY_NOTIFY_EMAIL=beant.singh36@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=beant.singh36@gmail.com
SMTP_PASS=ehhi evdj bvkx rmiy
SMTP_FROM="Sran Fort Website <beant.singh36@gmail.com>"

# WhatsApp notifications — inquiry sent to +91 77349 10001
INQUIRY_WHATSAPP_NUMBER=917734910001
# One-time setup: message "I allow callmebot to send me messages" to +34 644 44 71 67 on WhatsApp from 7734910001
CALLMEBOT_API_KEY=your-callmebot-api-key
