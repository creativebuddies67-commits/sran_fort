{
  "kind": "collectionType",
  "collectionName": "wedding_packages",
  "info": {
    "singularName": "wedding-package",
    "pluralName": "wedding-packages",
    "displayName": "Wedding Package",
    "description": "Wedding and event packages"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "shortDescription": {
      "type": "text"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "features": {
      "type": "json"
    },
    "tier": {
      "type": "enumeration",
      "enum": ["silver", "gold", "platinum", "royal"],
      "default": "gold"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"],
      "description": "Package photos on Wedding Packages page and homepage. Save and Publish after uploading."
    }
  }
}
