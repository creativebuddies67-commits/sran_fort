{
  "kind": "collectionType",
  "collectionName": "rooms",
  "info": {
    "singularName": "room",
    "pluralName": "rooms",
    "displayName": "Room",
    "description": "Hotel and guest rooms"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "shortDescription": {
      "type": "text"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "capacity": {
      "type": "integer",
      "default": 2
    },
    "amenities": {
      "type": "json"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"],
      "description": "Room photos shown on Rooms page and homepage. Upload 1–3 images, then Save and Publish."
    }
  }
}
