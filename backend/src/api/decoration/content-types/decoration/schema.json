{
  "kind": "collectionType",
  "collectionName": "decorations",
  "info": {
    "singularName": "decoration",
    "pluralName": "decorations",
    "displayName": "Decoration",
    "description": "Wedding and event decoration themes"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "shortDescription": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "enum": ["mandap", "stage", "entrance", "reception", "floral", "lighting", "theme"],
      "default": "theme"
    },
    "priceRange": {
      "type": "string"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"],
      "description": "Decoration photos on Decoration page. Save and Publish after uploading."
    }
  }
}
